@page "/favorites"
@using Terraria_Wiki.Components.Icons
@using Terraria_Wiki.Services
@using Terraria_Wiki.Models

<div class="page-anim page-content">

	<header class="page-header">
		<span class="page-title">收藏内容</span>
		<span class="sub-text">共找到 @favoriteCount 个结果</span>
	</header>
	<div class="list-container favorite-list">
		@if (favoriteCount == 0)
		{
			<div class="empty-state">
				<p>还没有收藏任何内容</p>
			</div>
		}
		else
		{

			<Virtualize @ref="_virtualizeComponent" ItemsProvider="LoadPages" Context="item" OverscanCount="5">
				<div class="wiki-card button" @onclick="() => AppService.OpenPageAsync(item.WikiTitle)">
					<div class="card-icon">
						<Icon Name="star-filled" Size="24" />
					</div>
					<div class="card-content">
						<div class="card-title">@item.WikiTitle</div>
						<div class="card-meta">收藏于 @item.FavoritedAt.ToString("yyyy/MM/dd")</div>
					</div>
					<button class="remove-btn" @onclick:stopPropagation="true" @onclick="() => RemoveAsync(item.WikiTitle)">
						取消
					</button>
				</div>
			</Virtualize>

		}

	</div>

</div>

@code {
	private Virtualize<WikiFavorite>? _virtualizeComponent;
	private int favoriteCount = 0;
	protected override void OnInitialized()
	{
		//订阅 Topbar 传来的搜索事件
		AppState.OnSearchQueryChanged += HandleSearchChanged;
	}

	public void Dispose()
	{
		AppState.OnSearchQueryChanged -= HandleSearchChanged;
	}
	protected override async Task OnInitializedAsync()
	{
		// 调用服务获取数量
		favoriteCount = await App.ContentDb.GetCountAsync<WikiFavorite>();

	}

	private async ValueTask<ItemsProviderResult<WikiFavorite>> LoadPages(ItemsProviderRequest request)
	{
		var query = AppState.SearchQuery?.Trim();

		if (string.IsNullOrEmpty(query))
		{
			// ================== 无搜索词：正常加载 ==================
			favoriteCount = await App.ContentDb.GetCountAsync<WikiFavorite>();

			var items = await App.ContentDb.GetWikiFavoritePagedAsync(request.StartIndex, request.Count);

			StateHasChanged();

			return new ItemsProviderResult<WikiFavorite>(items, favoriteCount);

		}
		else
		{
			// ================== 有搜索词：使用通用过滤加载 ==================

			// 1. 获取过滤后的总数
			favoriteCount = await App.ContentDb.GetFilteredCountAsync(
				tableName: "WikiFavorite",
				searchColumn: "WikiTitle",
				keyword: query);

			// 2. 获取过滤后的分页数据 (只拿必要的列，避开庞大的 Content 列)
			var items = await App.ContentDb.GetFilteredPagedAsync<WikiFavorite>(
				tableName: "WikiFavorite",
				selectColumns: "WikiTitle, FavoritedAt",
				searchColumn: "WikiTitle",
				keyword: query,
				orderByColumn: "FavoritedAt",
				startIndex: request.StartIndex,
				count: request.Count,
				isDesc: true
			);

			StateHasChanged();
			return new ItemsProviderResult<WikiFavorite>(items, favoriteCount);
		}
	}


	private async Task RemoveAsync(string title)
	{
		await App.ContentDb.DeleteItemAsync<WikiFavorite>(title);
		if (_virtualizeComponent != null)
		{
			await _virtualizeComponent.RefreshDataAsync();
			var query = AppState.SearchQuery?.Trim();
			if (query != "")
			{
				favoriteCount = await App.ContentDb.GetFilteredCountAsync(
					tableName: "WikiFavorite",
					searchColumn: "WikiTitle",
					keyword: query);
			}
			else
			{
				favoriteCount = await App.ContentDb.GetCountAsync<WikiFavorite>();
			}
			

		}
	}

	private async void HandleSearchChanged()
	{
		// 4. 当搜索词改变时，强制 Virtualize 丢弃当前数据，重新触发 LoadPages
		await InvokeAsync(async () =>
		{
			if (_virtualizeComponent != null)
			{
				await _virtualizeComponent.RefreshDataAsync();
				StateHasChanged();
			}
		});
	}


}

<style>

	.favorite-list{
		gap:8px;
	}
	.wiki-card {
		display: flex;
		align-items: center;
		padding: 4px 12px;
		border-radius: 12px;
		cursor: pointer;
	}


	.card-icon {
		margin-right: 16px;
		color: var(--blue-primary);
		display: flex;
		align-items: center;
	}

	.card-content {
		flex: 1;
		min-width: 0;
	}

	.card-title {
		font-weight: 500;
		font-size: 1rem;
		color: var(--text-primary);
		margin-bottom: 2px;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.card-meta {
		font-size: 0.8rem;
		color: var(--text-secondary);
	}

	.remove-btn {
		background: transparent;
		border: 1px solid var(--text-secondary);
		color: var(--text-secondary);
		padding: 4px 12px;
		border-radius: 99px;
		font-size: 0.8rem;
		cursor: pointer;
	}

		.remove-btn:hover {
			border-color: var(--red-primary);
			color: var(--red-primary);
			background-color: var(--red-tertiary);
		}
</style>
@page "/history"
@using Terraria_Wiki.Components.Icons
@using Terraria_Wiki.Models
@using Terraria_Wiki.Services

<div class="page-anim page-content">

	<header class="page-header">
		<span class="page-title">浏览历史</span>
		<span class="clear-btn sub-text" @onclick="ClearHistory">清空历史</span>
	</header>

	<div class="list-container timeline history-list">

		<Virtualize @ref="_virtualizeComponent" ItemsProvider="LoadPages" Context="entry" OverscanCount="10">
			<ItemContent>

				@if (entry.ShowDateHeader)
				{
					<div class="timeline-row header-row">
						<span class="group-title">@entry.DateLabel</span>
					</div>
				}
				<div class="timeline-row item-row">
					<div class="history-item button" @onclick="() => AppService.OpenPageAsync(entry.Data.WikiTitle)">
						<div class="time-stamp">@entry.Data.ReadAt.ToString("HH:mm")</div>
						<div class="item-info">
							<span class="item-name">@entry.Data.WikiTitle</span>
						</div>
					</div>
				</div>

			</ItemContent>
		</Virtualize>

	</div>
</div>

@code {

	private Virtualize<HistoryTimelineItem>? _virtualizeComponent;
	protected override void OnInitialized()
	{
		//订阅 Topbar 传来的搜索事件
		AppState.OnSearchQueryChanged += HandleSearchChanged;
	}

	public void Dispose()
	{
		AppState.OnSearchQueryChanged -= HandleSearchChanged;
	}

	private async ValueTask<ItemsProviderResult<HistoryTimelineItem>> LoadPages(ItemsProviderRequest request)
	{
		var query = AppState.SearchQuery?.Trim();

		int totalCount;
		List<WikiHistory> rawItems;
		WikiHistory? previousItem = null;

		if (string.IsNullOrEmpty(query))
		{
			// ================== 无搜索词：正常加载 ==================
			totalCount = await App.ContentDb.GetCountAsync<WikiHistory>();
			rawItems = await App.ContentDb.GetWikiHistoryPagedAsync(request.StartIndex, request.Count);

			if (request.StartIndex > 0)
			{
				var prevList = await App.ContentDb.GetWikiHistoryPagedAsync(request.StartIndex - 1, 1);
				previousItem = prevList.FirstOrDefault();
			}
		}
		else
		{
			// ================== 有搜索词：带过滤加载 ==================
			// 使用我们之前封装好的通用简化版过滤方法
			// 假设历史表搜的是 WikiTitle，按 ReadAt 降序排
			totalCount = await App.ContentDb.GetFilteredCountAsync<WikiHistory>("WikiTitle", query);

			rawItems = await App.ContentDb.GetFilteredPagedAsync<WikiHistory>(
				searchColumn: "WikiTitle",
				keyword: query,
				orderByColumn: "ReadAt",
				startIndex: request.StartIndex,
				count: request.Count,
				isDesc: true
			);

			// 【极其关键】：这里查的“上一条”也必须是带过滤条件的上一条！
			if (request.StartIndex > 0)
			{
				var prevList = await App.ContentDb.GetFilteredPagedAsync<WikiHistory>(
					searchColumn: "WikiTitle",
					keyword: query,
					orderByColumn: "ReadAt",
					startIndex: request.StartIndex - 1,
					count: 1,
					isDesc: true
				);
				previousItem = prevList.FirstOrDefault();
			}
		}

		// ================== 核心时间线逻辑 (合并复用，毫不干涉) ==================
		var resultItems = new List<HistoryTimelineItem>();
		string lastDateKey = previousItem != null ? GetDateLabel(previousItem.ReadAt) : "";

		foreach (var item in rawItems)
		{
			var currentLabel = GetDateLabel(item.ReadAt);
			bool needsHeader = currentLabel != lastDateKey;

			resultItems.Add(new HistoryTimelineItem
			{
				Data = item,
				ShowDateHeader = needsHeader,
				DateLabel = needsHeader ? currentLabel : ""
			});

			lastDateKey = currentLabel;
		}


		return new ItemsProviderResult<HistoryTimelineItem>(resultItems, totalCount);
	}




	private string GetDateLabel(DateTime dt)
	{
		if (dt.Date == DateTime.Today) return "今天";
		if (dt.Date == DateTime.Today.AddDays(-1)) return "昨天";
		return dt.ToString("M月d日");
	}

	//清空历史
	private async void ClearHistory()
	{
		bool isConfirmed = await Application.Current.MainPage?.DisplayAlert("提示", "确认清空历史记录吗？", "确定","取消");
		if (isConfirmed)
		{
			await App.ContentDb.DeleteItemsAsync<WikiHistory>();
			await _virtualizeComponent?.RefreshDataAsync();
			StateHasChanged();
		}

	}

	private async void HandleSearchChanged()
	{
		// 4. 当搜索词改变时，强制 Virtualize 丢弃当前数据，重新触发 LoadPages
		await InvokeAsync(async () =>
		{
			if (_virtualizeComponent != null)
			{
				await _virtualizeComponent.RefreshDataAsync();
				StateHasChanged();
			}
		});
	}

}

<style>
	.history-list{
		gap:4px;
		padding: 0 0 12px;
	}
	.clear-btn {
		background: transparent;
		border: none;
		color: var(--accent-color);
		cursor: pointer;
		font-weight: 500;
	}

		.clear-btn:hover {
			text-decoration: underline;
		}

	.timeline-row {
		display: flex;
		align-items: center;
		position: relative;
		z-index: 1;
	}

	/* 标题行样式 */
	.header-row {
		/* 不需要 margin-bottom，用高度撑开 */
		padding-top: 8px; /* 稍微调整文字位置 */
	}

	.group-title {
		padding-right: 12px;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--text-secondary);
		text-transform: uppercase;
		/* 确保它在最左边遮住线条 */
		display: inline-block;
	}

	/* 内容行样式 */
	.item-row {
		padding-left: 24px; /* 缩进 */
		width: 100%;
	}

	.history-item {
		display: flex;
		align-items: center;
		width: 100%;
		padding: 10px 12px; /* 减小 padding 以适应 48px 高度 */
		border-radius: 8px;

	}


	.time-stamp {
		font-size: 0.8rem;
		color: var(--text-secondary);
		width: 60px;
		font-variant-numeric: tabular-nums;
	}

	.item-name {
		font-size: 1rem;
		color: var(--text-primary);
		font-weight: 500;
	}
</style>